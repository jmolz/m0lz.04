# ── Case Pilot — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.

# Required: Anthropic API key for AI-powered drafting
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Override the default Claude model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Max tokens for AI responses (default: 4000)
# ANTHROPIC_MAX_TOKENS=4000

# Optional: Extended thinking mode (auto|adaptive|enabled|off)
# ANTHROPIC_THINKING_MODE=auto
# ANTHROPIC_THINKING_EFFORT=medium

# Optional: UI server port (default: 3210)
# PORT=3210
